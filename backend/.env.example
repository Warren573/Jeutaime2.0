# ==============================
# JeuTaime Backend — Variables d'environnement
# Copier en .env et remplir les valeurs
# ==============================

# --- Serveur ---
NODE_ENV=development
PORT=3000
API_PREFIX=/api

# --- Base de données PostgreSQL ---
DATABASE_URL="postgresql://user:password@localhost:5432/jeutaime?schema=public"

# --- JWT ---
JWT_ACCESS_SECRET=change_me_access_secret_32chars_min
JWT_REFRESH_SECRET=change_me_refresh_secret_32chars_min
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# --- Bcrypt ---
BCRYPT_ROUNDS=12

# --- CORS ---
# Séparer plusieurs origines par virgule
CORS_ORIGINS=http://localhost:8081,http://localhost:3000

# --- Uploads ---
UPLOAD_DIR=./storage/photos
MAX_FILE_SIZE_MB=5

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
RATE_LIMIT_AUTH_MAX=5
RATE_LIMIT_LETTERS_MAX=20
RATE_LIMIT_LETTERS_WINDOW_MS=3600000
RATE_LIMIT_REPORTS_MAX=5
RATE_LIMIT_REPORTS_WINDOW_MS=3600000
RATE_LIMIT_PHOTO_UPLOAD_MAX=10
RATE_LIMIT_PHOTO_UPLOAD_WINDOW_MS=3600000

# --- Logiciel ---
LOG_LEVEL=info
